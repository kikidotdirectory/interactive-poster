{
	"compilerOptions": {
		"lib": ["dom", "dom.iterable", "deno.ns"]
	},
	"tasks": {
		"transpile": "deno bundle -o dist/sketch.js src/sketch.ts --watch",
		"build": "deno bundle --minify -o dist/sketch.js src/sketch.ts",
		"serve": "deno run --allow-net --allow-read --allow-env --allow-sys jsr:@kastrophony/live-server dist/",
		"dev": "deno task transpile & deno task serve"
	},
	"imports": {
		"p5": "npm:@types/p5@^1.7.7"
	}
}
